# Backend (FastAPI) — plantilla
# Copiar a .env. Ver DEPLOY_CLOUDPANEL.md

# Producción (CloudPanel / VPS)
DATABASE_URL=postgresql://lepra_user:TU_PASSWORD@localhost:5432/lepra
SECRET_KEY=generar_clave_larga_y_segura

# Desarrollo local (si DATABASE_URL está vacío, usa estas)
# DB_USER=postgres
# DB_PASSWORD=tu_password_local
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=lepra

# Admin bootstrap (scripts/create_admin.py)
ADMIN_EMAIL=admin@lepra.local
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin
